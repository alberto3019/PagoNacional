# .env.example
# Copiar este archivo como .env y completar los valores reales

# ── Supabase ──────────────────────────────────────────────────
VITE_SUPABASE_URL=https://xxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Cloudinary ────────────────────────────────────────────────
VITE_CLOUDINARY_CLOUD_NAME=tu_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=pago_nacional_preset

# ── Resend (emails) — solo servidor: /api/email (no exponer en el navegador) ──
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── App ───────────────────────────────────────────────────────
# Dominio público del sistema (sin barra final). Ej.: https://www.pagonacional.com
VITE_APP_URL=https://www.pagonacional.com
VITE_ADMIN_EMAIL=admin@pagonacional.com.ar
VITE_ADMIN_USER=admin
VITE_ADMIN_PASS=123456

# ── Prestamista (Términos y contratos) ────────────────────────
# Si la fila en Supabase (prestamista_config) está vacía, se usan estos valores como respaldo.
VITE_PRESTAMISTA_NOMBRE=
VITE_PRESTAMISTA_CUIT=
VITE_PRESTAMISTA_DOMICILIO=
VITE_PRESTAMISTA_EMAIL=
VITE_PRESTAMISTA_TELEFONO=
